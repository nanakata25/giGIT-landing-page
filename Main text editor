#include <stdio.h>

void showMenu() {
    printf("\n=== TEXT EDITOR ===\n");
    printf("1. New File\n");
    printf("2. Open File\n");
    printf("3. Write Text\n");
    printf("4. Display Text\n");
    printf("5. Save File\n");
    printf("6. Exit\n");
}

int main() {
    int choice;
    do {
        showMenu();
        printf("Pilih: ");
        scanf("%d", &choice);
        switch(choice) {
            case 1:
                printf("Fitur New File belum dibuat\n");
                break;
            case 2:
                printf("Fitur Open File belum dibuat\n");
                break;
            case 3:
                printf("Fitur Write Text belum dibuat\n");
                break;
            case 4:
                printf("Fitur Display Text belum dibuat\n");
                break;
            case 5:
                printf("Fitur Save File belum dibuat\n");
                break;
        }
    } while(choice != 6);
    return 0;
}